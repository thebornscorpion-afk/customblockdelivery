# Copy to .env.local for local testing, or set these in Vercel → Settings → Environment Variables.

# Preferred: email + password (the proxy logs in and auto-refreshes the token)
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=

# Fallback if you only have a token (expires ~every 10 days, needs manual rotation)
# SHIPROCKET_TOKEN=

# Required: your pickup/warehouse pincode (6 digits)
WAREHOUSE_PINCODE=

# Optional: default parcel weight in kg
DEFAULT_WEIGHT=0.5

# Optional but recommended: restrict who can call the proxy (comma-separated)
ALLOWED_ORIGINS=https://sooperbrains.com,https://www.sooperbrains.com
